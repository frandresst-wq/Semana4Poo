@startuml  
skinparam classAttributeIconSize 0

class Persona {
    - nombre: string
    - rut: string
    + Persona(nombre: string, rut: string)
    + mostrar_informacion(): void  
}

class Estudiante {
    - carrera: string 
    - arancel_base: float
    - porcentaje_beca: float
    + Estudiante(nombre: string, rut: string, carrera: string)
    + mostrar_informacion(): void
    + aplicar_beca(porcentaje: float): void
    + calcular_arancel_final(): float
}

class Docente {
    - especialidad: string
    + Docente(nombre: string, rut: string, especialidad: string)
    + mostrar_informacion(): void
}

class Asignatura {
    - id_asignatura: string
    - nombre_asignatura: string
    + Asignatura(id_asignatura: string, nombre_asignatura: string)
    + obtener_nombre_asignatura(): string
}

class Curso {
    - semestre: string
    - asignatura: Asignatura
    - docente: Docente
    - estudiantes_inscritos: List<Estudiante>
    - calificaciones: Dictionary
    + Curso(asignatura: Asignatura, docente: Docente, semestre: string)
    + inscribir_estudiante_curso(estudiante: Estudiante): boolean
    + asignar_calificacion(estudiante: Estudiante, calificacion: float): void
    + determinar_aprobacion(estudiante: Estudiante): boolean
}

Persona <|-- Estudiante
Persona <|-- Docente