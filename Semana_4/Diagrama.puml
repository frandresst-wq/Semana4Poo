@startuml  
skinparam classAttributeIconSize 0

class Persona {
    - nombre: string
    - rut: string
    + Persona(nombre: string, rut: string)
    + mostrar_informacion(): void  
}

class Estudiante {
    - carrera: string 
    - arancel_base: float
    - porcentaje_beca: float
    + Estudiante(nombre: string, rut: string, carrera: string)
    + mostrar_informacion(): void
    + aplicar_beca(porcentaje: float): void
    + calcular_arancel_final(): float
}

class Docente {
    - especialidad: string
    + Docente(nombre: string, rut: string, especialidad: string)
    + mostrar_informacion(): void
}

class Asignatura {
    + asignar_docente
    + aprobar_reprobar_asignatura
}

class Curso {
    +inscribir_estudiante_curso
}

Persona <|-- Estudiante
Persona <|-- Docente